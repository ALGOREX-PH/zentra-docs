# ---------------------------------------------------------------------------
# Zentra Docs -- environment variables
#
# Copy to .env.local and fill in. .env*.local is gitignored, so real values
# never reach the repository; the deployed values live in the Vercel project
# settings instead.
#
#   cp .env.example .env.local
#
# Every variable the code actually reads is listed here. If you add a
# process.env lookup, add it here too -- this file is the contract between the
# code and whoever has to run it.
# ---------------------------------------------------------------------------

# Neon serverless Postgres connection string. Backs the feedback API and the
# /api/health readiness probe.
#
# Required by:  src/lib/db.ts  ->  /api/feedback, /api/health
# Optional:     yes, in the sense that the rest of the site runs without it --
#               the feedback endpoints answer 503 and /api/health reports
#               "degraded" rather than the build or the other routes failing.
# Get one at:   https://neon.tech (free tier is enough)
# Then apply:   psql "$DATABASE_URL" -f db/schema.sql
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Canonical public origin, used to build absolute URLs for metadata, Open Graph
# images and the sitemap.
#
# Required by:  src/lib/site.ts, src/app/layout.tsx, src/app/sitemap.ts
# Local dev:    http://localhost:3000
# Production:   falls back to VERCEL_PROJECT_PRODUCTION_URL, which Vercel sets
#               automatically -- so this only needs setting for a custom domain
#               or when running outside Vercel.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Shared secret gating the operator-only endpoints:
#   GET   /api/admin/users     CSV export of the onboarding registry
#   PATCH /api/admin/feedback  hide or unhide a moderated feedback row
#
# Required by:  src/lib/api/auth.ts
# Behaviour:    if this is unset or empty, those endpoints ALWAYS deny with 503.
#               A missing secret never means "open" -- they fail closed.
# Generate:     openssl rand -hex 32
# Send as:      Authorization: Bearer <token>   (or the x-admin-token header)
#
# This is an operator gate, not a user authentication system. It exists because
# the registry holds names and email addresses, so its export must not be public.
ADMIN_TOKEN=""

# ---------------------------------------------------------------------------
# Set for you -- do not add these by hand
#
#   NODE_ENV                        set by Next.js; gates debug logging and
#                                   stack traces in src/lib/api/logger.ts
#   VERCEL_PROJECT_PRODUCTION_URL   set by Vercel; the NEXT_PUBLIC_SITE_URL
#                                   fallback in production
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Deliberately absent: anything holding a Stellar secret key.
#
# The dApp never sees one. Transactions are built in the browser, signed by the
# user's own wallet extension, and submitted as signed XDR -- the server has no
# signing authority and no key to leak. Contract deployment is a separate
# operator task (contracts/deploy.sh) run from your own funded account.
# ---------------------------------------------------------------------------
